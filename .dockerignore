# Version control
.git/
.gitignore

# Python cache
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache/
**/*.egg-info/
dist/
build/

# MLflow experiment data (runtime, not baked into image)
mlruns/

# Pipeline output (large intermediate files not needed by the app)
algorithms/machine_learning_algorithms/supervised/output/

# Dev/test artifacts
tests/results/
**/*.log
**/*.tmp

# Notebooks
**/.ipynb_checkpoints/
**/*.ipynb

# OS artifacts
.DS_Store
**/.DS_Store
Thumbs.db

# Secrets
keys.txt
.env
.env.*
secrets/

# CI/CD
.github/
.circleci/

# Documentation source (keep only final docs)
**/*.tex
